{
	"$schema": "https://json.schemastore.org/package.json",
	"name": "node_backend_boilerplate",
	"version": "8.0.1",
	"description": "Node.js Boilerplate for Back-End using TypeScript",
	"license": "MIT",
	"private": false,
	"author": "Álvaro Davi Santos Alves <alvaro-davi1@hotmail.com>",
	"contributors": [
		"Álvaro Davi Santos Alves <alvaro-davi1@hotmail.com>"
	],
	"repository": "https://github.com/AlvaroDavi5/Node_BackEnd_Boilerplate-TypeScript.git",
	"main": "./src/main.ts",
	"engineStrict": true,
	"engines": {
		"node": ">=24.0.x <=24.x.x",
		"npm": ">=11.6.1 <=11.x.x",
		"yarn": ">=1.22.x <2.x.x"
	},
	"os": [
		"linux",
		"ubuntu",
		"win32"
	],
	"keywords": [
		"boilerplate",
		"node",
		"typescript",
		"javascript",
		"nestjs"
	],
	"scripts": {
		"typecheck": "tsc --project tsconfig.json --noEmit",
		"build": "nest build",
		"build:webpack": "npm run build && webpack --config webpack.config.ts",
		"start": "nest start",
		"start:prod": "node build/src/main.js",
		"start:webpack": "node build/webpack.js",
		"start:dev": "cross-env NODE_ENV=dev nodemon --config nodemon.json",
		"start:debug": "nest start --debug --watch",
		"security-check": "ts-node --project tsconfig.json ./scripts/security-check.ts",
		"mock-dependencies": "ts-node --project tsconfig.json ./scripts/mock-dependencies.ts",
		"receive-messages": "ts-node --project tsconfig.json scripts/receive-messages.ts",
		"send-message": "ts-node --project tsconfig.json ./scripts/send-message.ts",
		"db:seed": "ts-node --project tsconfig.json ./scripts/seed.ts",
		"db:create": "typeorm-extension db:create -d build/src/modules/core/infra/database/db.config.js",
		"db:drop": "typeorm-extension db:drop -d build/src/modules/core/infra/database/db.config.js",
		"db:schema-sync": "typeorm schema:sync -d build/src/modules/core/infra/database/db.config.js",
		"db:schema-drop": "typeorm schema:drop -d build/src/modules/core/infra/database/db.config.js",
		"db:schema-log": "typeorm schema:log -d build/src/modules/core/infra/database/db.config.js",
		"db:cache-clear": "typeorm cache:clear -d build/src/modules/core/infra/database/db.config.js",
		"db:query-exec": "typeorm query -d build/src/modules/core/infra/database/db.config.js",
		"db:migration-show": "typeorm migration:show -d build/src/modules/core/infra/database/db.config.js",
		"db:migration-run": "typeorm migration:run -d build/src/modules/core/infra/database/db.config.js",
		"db:migration-revert": "typeorm migration:revert -d build/src/modules/core/infra/database/db.config.js",
		"db:migration-generate": "typeorm migration:generate -d build/src/modules/core/infra/database/db.config.js",
		"db:migration-create": "typeorm migration:create",
		"db:entity-create": "typeorm entity:create",
		"db:subscriber-create": "typeorm subscriber:create",
		"test": "npm run test:unit && npm run test:integration && npm run test:e2e",
		"test:coverage": "npm run test:unit:coverage && npm run test:integration:coverage && npm run test:e2e:coverage",
		"test:unit": "jest -c tests/jest.config.ts --verbose --runInBand",
		"test:unit:#it": "jest -t=#it -c tests/jest.config.ts --verbose --runInBand",
		"test:unit:watch": "jest -c tests/jest.config.ts --watch --verbose --detectOpenHandles",
		"test:unit:coverage": "jest -c tests/jest.config.ts --coverage --runInBand",
		"test:integration": "jest -c tests/jest.integration.config.ts",
		"test:integration:#it": "jest -t=#it -c tests/jest.integration.config.ts",
		"test:integration:watch": "jest -c tests/jest.integration.config.ts --watch --detectOpenHandles",
		"test:integration:coverage": "jest -c tests/jest.integration.config.ts --runInBand --coverage",
		"test:e2e": "jest -c tests/jest.e2e.config.ts --runInBand",
		"test:e2e:#it": "jest -t=#it -c tests/jest.e2e.config.ts --runInBand",
		"test:e2e:watch": "jest -c tests/jest.e2e.config.ts --watch --detectOpenHandles",
		"test:e2e:coverage": "jest -c tests/jest.e2e.config.ts --runInBand --coverage --runInBand",
		"sonar:prepare": "npm run coverage:merge:prepare && npm run coverage:merge:unify && npm run coverage:merge:report",
		"sonar:scan": "sonar-scanner",
		"coverage:merge:prepare": "cp coverage/unit/coverage-final.json coverage/unit.json && cp coverage/integration/coverage-final.json coverage/integration.json && cp coverage/e2e/coverage-final.json coverage/e2e.json",
		"coverage:merge:unify": "nyc merge coverage/ coverage/coverage-final.json",
		"coverage:merge:report": "nyc report -t coverage/ --report-dir coverage/ --reporter=html --reporter=cobertura",
		"backstage:build-docs": "npx @techdocs/cli build",
		"backstage:view-docs": "npx @techdocs/cli serve",
		"lint": "eslint \"{src,tests,scripts}/**/*.{ts,js}\"",
		"lint:fix": "eslint \"{src,tests,scripts}/**/*.{ts,js}\" --quiet --fix",
		"typeorm:cli": "ts-node --project tsconfig.build.json ./node_modules/typeorm/cli -d ./src/modules/core/infra/database/db.config.ts",
		"commit": "git-cz",
		"versioning": "semantic-release",
		"postinstall": "lefthook install"
	},
	"config": {
		"commitizen": {
			"path": "cz-conventional-changelog"
		}
	},
	"dependencies": {
		"@apollo/gateway": "^2.13.3",
		"@apollo/server": "^5.5.0",
		"@as-integrations/fastify": "^3.1.0",
		"@aws-sdk/client-cognito-identity-provider": "^3.873.0",
		"@aws-sdk/client-s3": "^3.873.0",
		"@aws-sdk/client-sns": "^3.873.0",
		"@aws-sdk/client-sqs": "^3.873.0",
		"@aws-sdk/s3-request-presigner": "^3.873.0",
		"@fastify/formbody": "^8.0.2",
		"@fastify/multipart": "^9.4.0",
		"@fastify/static": "^9.1.1",
		"@nestjs/apollo": "^13.2.5",
		"@nestjs/common": "^11.1.19",
		"@nestjs/config": "^4.0.4",
		"@nestjs/core": "^11.1.19",
		"@nestjs/devtools-integration": "^0.2.1",
		"@nestjs/event-emitter": "^3.0.1",
		"@nestjs/graphql": "^13.2.5",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-fastify": "^11.1.19",
		"@nestjs/platform-socket.io": "^11.1.19",
		"@nestjs/platform-ws": "^11.1.19",
		"@nestjs/schedule": "^6.1.3",
		"@nestjs/swagger": "^11.3.0",
		"@nestjs/throttler": "^6.5.0",
		"@nestjs/websockets": "^11.1.19",
		"@sentry/nestjs": "^10.5.0",
		"@sentry/profiling-node": "^10.5.0",
		"@ssut/nestjs-sqs": "^3.0.1",
		"@swc/cli": "^0.8.1",
		"@swc/core": "^1.13.21",
		"@swc/helpers": "^0.5.21",
		"@swc/jest": "^0.2.39",
		"axios": "^1.15.0",
		"axios-retry": "^4.5.0",
		"bcrypt": "^6.0.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.4",
		"compression": "^1.8.1",
		"cors": "^2.8.6",
		"cross-env": "^10.0.0",
		"dotenv": "^17.2.4",
		"ejs": "^3.1.10",
		"fastify": "^5.8.5",
		"graphql": "^16.13.2",
		"ioredis": "^5.8.2",
		"joi": "^18.0.2",
		"jsonwebtoken": "^9.0.3",
		"luxon": "^3.7.2",
		"mongodb": "^6.18.0",
		"multer": "^2.1.1",
		"path": "^0.12.7",
		"pg": "^8.16.3",
		"pg-hstore": "^2.3.4",
		"reflect-metadata": "^0.2.2",
		"rxjs": "^7.8.2",
		"socket.io": "^4.8.3",
		"socket.io-client": "^4.8.3",
		"ts-morph": "^25.0.1",
		"ts-node": "^10.9.2",
		"typeorm": "^0.3.28",
		"typescript": "^5.9.3",
		"uuid": "^11.1.0",
		"winston": "^3.17.0"
	},
	"overrides": {
		"fastify": "$fastify"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.2.0",
		"@commitlint/config-conventional": "^20.2.0",
		"@eslint/js": "^9.39.4",
		"@nestjs/cli": "^11.0.21",
		"@nestjs/schematics": "^11.0.10",
		"@nestjs/testing": "^11.1.19",
		"@semantic-release/commit-analyzer": "^13.0.1",
		"@semantic-release/git": "^10.0.1",
		"@semantic-release/github": "^12.0.6",
		"@semantic-release/npm": "^13.1.5",
		"@semantic-release/release-notes-generator": "^14.1.0",
		"@sentry/cli": "^2.58.5",
		"@types/bcrypt": "^6.0.0",
		"@types/compression": "^1.8.1",
		"@types/ejs": "^3.1.5",
		"@types/eslint-plugin-security": "^3.0.1",
		"@types/jest": "^30.0.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.1.0",
		"@types/node": "^24.12.2",
		"@types/supertest": "^6.0.3",
		"@types/uuid": "^10.0.0",
		"@types/webpack-node-externals": "^3.0.4",
		"@types/ws": "^8.18.1",
		"@typescript-eslint/eslint-plugin": "^8.58.2",
		"@typescript-eslint/parser": "^8.58.2",
		"@typescript-eslint/scope-manager": "^8.58.2",
		"@typescript-eslint/typescript-estree": "^8.58.2",
		"@typescript-eslint/utils": "^8.58.2",
		"child_process": "^1.0.2",
		"commitizen": "^4.3.1",
		"cz-conventional-changelog": "^3.3.0",
		"eslint": "^9.39.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^54.7.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-security": "^3.0.1",
		"globals": "^16.5.0",
		"jest": "^30.3.0",
		"jest-cli": "^30.3.0",
		"jest-sonar-reporter": "^2.0.0",
		"lefthook": "^1.13.6",
		"mongo-mock": "^4.2.0",
		"nodemon": "^3.1.14",
		"nyc": "^17.1.0",
		"semantic-release": "^25.0.3",
		"sonarqube-scanner": "^4.3.6",
		"source-map-support": "^0.5.21",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.9",
		"ts-loader": "^9.5.7",
		"ts-node-dev": "^2.0.0",
		"tsconfig-paths": "^4.2.0",
		"typeorm-extension": "^3.9.0",
		"webpack": "^5.105.4",
		"webpack-cli": "^6.0.1",
		"webpack-node-externals": "^3.0.0"
	}
}